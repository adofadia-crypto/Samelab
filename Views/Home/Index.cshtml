@model IEnumerable<SamelabWeb.Controllers.EmpleadoResultado>

@{
    ViewData["Title"] = "Dashboard SAMELAB";
}

<style>
    /* Estilos Modernos y Contenedores */
    body { background-color: #f8f9fa; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
    .card-dashboard { border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.08); padding: 25px; background: #fff; margin-bottom: 20px; border: none; }
    .header-section { background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%); color: white; padding: 40px 20px; border-radius: 15px; margin-bottom: 30px; box-shadow: 0 4px 15px rgba(30, 60, 114, 0.3); }
    
    /* Pestañas Personalizadas */
    .nav-tabs { border-bottom: none; }
    .nav-tabs .nav-link { border: none; color: #6c757d; font-weight: 600; padding: 15px 25px; transition: 0.3s; border-radius: 10px; margin: 0 5px; }
    .nav-tabs .nav-link:hover { background: rgba(30, 60, 114, 0.05); }
    .nav-tabs .nav-link.active { color: #1e3c72; border-bottom: 4px solid #1e3c72; background: transparent; }

    /* Badges de Riesgo */
    .badge { font-size: 0.85rem; padding: 8px 12px; border-radius: 8px; }
    .bg-high { background-color: #dc3545 !important; color: white; }
    .bg-medium { background-color: #ffc107 !important; color: #000; }
    .bg-low { background-color: #198754 !important; color: white; }

    /* Gráficas de Python */
    .img-python { width: 100%; border-radius: 12px; border: 1px solid #eee; margin-top: 10px; transition: transform 0.3s ease; box-shadow: 0 2px 8px rgba(0,0,0,0.05); }
    .img-python:hover { transform: scale(1.02); }

    /* Power BI Container */
    .iframe-container { position: relative; width: 100%; padding-top: 56.25%; border-radius: 15px; border: 1px solid #eee; overflow: hidden; background: #fdfdfd; }
    .responsive-iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none; }

    /* Tabla scroll */
    .table-responsive { border-radius: 10px; overflow: hidden; }
</style>

<div class="container mt-4">
    <div class="header-section text-center">
        <h1 class="display-5 fw-bold">SAMELAB: Talent Intelligence Platform</h1>
        <p class="lead mb-0">Análisis Predictivo de Rotación y Visualización de Datos (TFM)</p>
    </div>

    <ul class="nav nav-tabs mb-4 justify-content-center" id="tfmTabs" role="tablist">
        <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#presentacion">📌 Proyecto</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#carga">🤖 Análisis IA</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#graficas">📊 Gráficas Python</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#bi">📈 Power BI</button></li>
    </ul>

    <div class="tab-content" id="tfmTabsContent">
        
        <div class="tab-pane fade show active" id="presentacion" role="tabpanel">
            <div class="card-dashboard">
                <div class="row align-items-center">
                    <div class="col-md-8 border-end px-4">
                        <h2 class="text-primary fw-bold">¿Qué es SAMELAB?</h2>
                        <p class="fs-5 text-muted">Plataforma de <strong>Talent Analytics</strong> diseñada para predecir la probabilidad de deserción laboral mediante modelos de Machine Learning (Regresión Logística).</p>
                        <hr>
                        <h5 class="fw-bold text-dark">Arquitectura del Sistema:</h5>
                        <ul class="list-unstyled mt-3">
                            <li><i class="bi bi-check-circle-fill text-success me-2"></i><strong>Backend:</strong> .NET Core 8 & SQL Server (Azure)</li>
                            <li><i class="bi bi-check-circle-fill text-success me-2"></i><strong>Motor IA:</strong> Python 3.11 + Scikit-Learn</li>
                            <li><i class="bi bi-check-circle-fill text-success me-2"></i><strong>Visualización:</strong> Matplotlib, Seaborn & Power BI</li>
                        </ul>
                    </div>
                    <div class="col-md-4 text-center">
                        <img src="https://cdn-icons-png.flaticon.com/512/2103/2103633.png" class="img-fluid p-4" style="max-width: 250px; opacity: 0.9;">
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="carga" role="tabpanel">
            <div class="row">
                <div class="col-md-4">
                    <div class="card-dashboard text-center">
                        <h4 class="mb-3 fw-bold">Panel de Control</h4>
                        <form asp-action="SubirCSV" method="post" enctype="multipart/form-data" class="mb-3">
                            <label class="form-label small text-muted">Paso 1: Ingesta de Datos (CSV)</label>
                            <input type="file" name="archivo" class="form-control mb-2" accept=".csv" required />
                            <button type="submit" class="btn btn-primary w-100 shadow-sm">Cargar Empleados</button>
                        </form>
                        
                        <form asp-action="EjecutarIA" method="post">
                            <label class="form-label small text-muted">Paso 2: Procesamiento de IA</label>
                            <button type="submit" class="btn btn-warning w-100 fw-bold shadow-sm">Ejecutar Predicciones</button>
                        </form>

                        <div class="mt-4 pt-3 border-top">
                            <h6 class="small fw-bold text-uppercase text-muted">Resumen de Riesgo</h6>
                            <canvas id="atritionChart"></canvas>
                        </div>
                    </div>
                </div>

                <div class="col-md-8">
                    <div class="card-dashboard">
                        <h4 class="mb-3 fw-bold">Predicciones de Atrición</h4>
                        <div class="table-responsive" style="max-height: 550px;">
                            <table class="table table-hover align-middle">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Departamento</th>
                                        <th>Puesto</th>
                                        <th class="text-center">Probabilidad</th>
                                        <th class="text-center">Nivel Riesgo</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model != null && Model.Any())
                                    {
                                        foreach (var emp in Model)
                                        {
                                            <tr>
                                                <td>@emp.Department</td>
                                                <td>@emp.JobRole</td>
                                                <td class="text-center"><span class="fw-bold">@emp.Probability%</span></td>
                                                <td class="text-center">
                                                    @{
                                                        string cssClass = emp.Prediction == "High" ? "bg-high" : (emp.Prediction == "Medium" ? "bg-medium" : "bg-low");
                                                    }
                                                    <span class="badge @cssClass w-75">@emp.Prediction.ToUpper()</span>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="4" class="text-center py-4 text-muted">No hay datos procesados. Cargue un CSV y ejecute la IA.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="graficas" role="tabpanel">
            <div class="card-dashboard">
                <h3 class="mb-4 fw-bold text-primary">Reporte Estadístico (Python Matplotlib)</h3>
                <div class="row">
                    <div class="col-md-6 mb-4">
                        <h6 class="text-center text-uppercase fw-bold text-muted small">Impacto por Departamento</h6>
                        <img src="~/images/grafica_depto.png" class="img-python" onerror="this.src='https://placehold.co/600x400?text=Procese+la+IA+para+generar+gráfica'">
                    </div>
                    <div class="col-md-6 mb-4">
                        <h6 class="text-center text-uppercase fw-bold text-muted small">Densidad de Abandono</h6>
                        <img src="~/images/grafica_edad.png" class="img-python" onerror="this.src='https://placehold.co/600x400?text=Procese+la+IA+para+generar+gráfica'">
                    </div>
                    <div class="col-md-12">
                        <h6 class="text-center text-uppercase fw-bold text-muted small">Análisis de Probabilidad por Nivel de Riesgo</h6>
                        <img src="~/images/grafica_satisfaccion.png" class="img-python" onerror="this.src='https://placehold.co/1200x400?text=Procese+la+IA+para+generar+gráfica'">
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="bi" role="tabpanel">
            <div class="card-dashboard">
                <h3 class="mb-3 fw-bold text-primary">Business Intelligence Dashboard</h3>
                <div class="iframe-container shadow-sm">
                    <iframe class="responsive-iframe" 
                            src="https://app.powerbi.com/view?r=eyJrIjoiZGE2NmExODYtZDM2YS00N2EzLTg1MzMtYTVkOGQ0YzU3MGFkIiwidCI6ImQxMzQ3MmY3LTVkMmQtNGU5NS1iNmIwLWZhNWE1ODhjODMyZCIsImMiOjR9" 
                            allowFullScreen="true"></iframe>
                </div>
                <p class="mt-3 text-muted small text-center"><i class="bi bi-info-circle me-1"></i> El reporte de Power BI ofrece una vista interactiva basada en los datos históricos del dataset.</p>
            </div>
        </div>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        // Inicialización de la Gráfica de Dona (Chart.js)
        const ctx = document.getElementById('atritionChart').getContext('2d');
        
        // Obtenemos datos de ViewBag o inicializamos en cero
        const high = @(ViewBag.High ?? 0);
        const medium = @(ViewBag.Medium ?? 0);
        const low = @(ViewBag.Low ?? 0);

        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: ['Alto', 'Medio', 'Bajo'],
                datasets: [{
                    data: [high, medium, low],
                    backgroundColor: ['#dc3545', '#ffc107', '#198754'],
                    borderWidth: 0,
                    hoverOffset: 15
                }]
            },
            options: { 
                cutout: '70%',
                plugins: { 
                    legend: { position: 'bottom', labels: { padding: 20, font: { size: 12, weight: 'bold' } } } 
                } 
            }
        });
    });

    // Ajuste automático para el iframe de Power BI al cambiar de pestaña
    var biTab = document.querySelector('button[data-bs-target="#bi"]');
    biTab.addEventListener('shown.bs.tab', function () {
        var iframe = document.querySelector('#bi iframe');
        var currentSrc = iframe.src;
        // Solo refrescamos si es necesario para asegurar el renderizado responsivo
        iframe.src = currentSrc;
    });
</script>